{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "types": ["@rsbuild/core/types"],
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}
